# Canonical site URL is hard-coded in lib/site.ts (SITE.url); no env needed.

# Server-side quote delivery (app/api/quote). Unset = submissions are logged
# server-side only. Set HOST/USER/PASS/QUOTE_TO to enable SMTP email.
#
# Using Gmail (printcircuitsales@gmail.com): the account needs 2-Step
# Verification ON, then create an "App Password" (Google Account → Security →
# App passwords) and paste it as SMTP_PASS *without spaces*. Set these in the
# Vercel dashboard, NOT in the code:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=printcircuitsales@gmail.com
SMTP_PASS=          # 16-char Gmail app password, no spaces (set in Vercel / .env.local)
QUOTE_TO=printcircuitsales@gmail.com
QUOTE_FROM=printcircuitsales@gmail.com

# Client-side EmailJS fallback (components/contact/QuoteForm). Optional — the
# form posts to /api/quote first; EmailJS only fires if these are all set.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
